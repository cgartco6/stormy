version: '3'
services:
  stormy:
    build: .
    ports:
      - "5000:5000"
    volumes:
      - ~/.stormy:/root/.stormy   # persist config and memory
      - /dev/snd:/dev/snd         # audio (Linux)
    devices:
      - /dev/snd:/dev/snd
    environment:
      - LLM_MODE=local
      - LOCAL_LLM_URL=http://ollama:11434/api/generate
    depends_on:
      - ollama
  ollama:
    image: ollama/ollama
    volumes:
      - ollama_data:/root/.ollama
volumes:
  ollama_data:
